# ==================== 应用配置 ====================
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1
ADMIN_API_PREFIX=/api/admin

# ==================== 数据库配置 ====================
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_password
DB_DATABASE=treehole
DB_SYNC=true

# ==================== Redis配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# ==================== JWT配置 ====================
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_ADMIN_SECRET=your_admin_jwt_secret_key_change_in_production
JWT_ADMIN_EXPIRES_IN=24h

# ==================== 微信小程序配置 ====================
WEIXIN_APP_ID=your_weixin_app_id
WEIXIN_APP_SECRET=your_weixin_app_secret

# ==================== 支付宝小程序配置 ====================
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_APP_SECRET=your_alipay_app_secret

# ==================== 抖音小程序配置 ====================
DOUYIN_APP_ID=your_douyin_app_id
DOUYIN_APP_SECRET=your_douyin_app_secret

# ==================== 腾讯云COS配置 ====================
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key
COS_BUCKET=treehole-assets
COS_REGION=ap-beijing
COS_URL=https://assets.treehole.com

# ==================== 风控配置 ====================
MAX_COORDINATES=1000000
IP_REGISTRATION_LIMIT=3
LOGIN_FAILURE_LIMIT=5
LOGIN_LOCK_DURATION=30
FREEZE_DURATION_DAYS=5
REPORT_THRESHOLD_1=5
REPORT_THRESHOLD_2=10
REPORT_THRESHOLD_3=3
MESSAGE_EXPIRE_DAYS=90
DAILY_SEND_LIMIT=3
DAILY_RECEIVE_LIMIT=5
MAX_MESSAGE_LENGTH=500
MAX_COORDINATE_MESSAGES=5

# ==================== 内容审核配置 ====================
SENSITIVE_WORDS_URL=http://127.0.0.1:8080/sensitive-words
CONTENT_MODERATION_ENABLED=true
